{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/mockup-sandbox/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "artifacts/mockup-sandbox/dist"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/artifacts/mockup-sandbox/dist/$1" }
  ]
}
